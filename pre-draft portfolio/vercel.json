{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/skills",
      "dest": "/skills.html"
    },
    {
      "src": "/works",
      "dest": "/works.html"
    },
    {
      "src": "/feedbacks",
      "dest": "/feedbacks.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}